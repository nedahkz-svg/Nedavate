# ── Nedavate booking links (Cal.com) ──────────────────────────────────────────
# Copy this file to `.env.local` and replace with your real Cal.com links.
#
# 1. Create a free account at https://cal.com
# 2. Create two event types:
#      • "Free Strategy Call" (20 min, no price)
#      • "AI Strategy Session" (60 min) — install the Stripe app in Cal.com and
#        enable payment on this event so visitors pay when they book.
# 3. The link below is the part after cal.com/  e.g.  "neda/free-strategy-call".
#
# While testing, you can point both at the same free event.

NEXT_PUBLIC_CAL_FREE_LINK=your-username/free-strategy-call
NEXT_PUBLIC_CAL_PAID_LINK=your-username/ai-strategy-session

# ── Lead magnet email capture (optional but recommended) ──────────────────────
# The checklist signup form (/api/subscribe) forwards emails to ONE of these.
# Pick whichever you use. If none are set, the form still works in dev but the
# email is NOT stored (a warning is logged).
#
# Option A — ConvertKit (set both):
# CONVERTKIT_API_KEY=your_convertkit_api_key
# CONVERTKIT_FORM_ID=1234567
#
# Option B — Generic webhook (Zapier / Make / n8n / Google Sheet, etc.):
# LEAD_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxx/yyyy

# ── AI Chatbot (RAG + memory + tools, 3 channels) ──────────────────────────
# Apply supabase/chatbot-schema.sql in the Supabase SQL editor first, then
# run `npx tsx scripts/ingest-kb.ts` to populate the knowledge base.
#
# Server-only Supabase key for chatbot tables (Project Settings → API →
# service_role). Never expose this client-side.
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter — chat completions + tool calling. Get a key at openrouter.ai.
# Default is an open-weight model with reliable tool calling. Other open-weight
# options that support tools on OpenRouter: qwen/qwen-2.5-72b-instruct,
# mistralai/mixtral-8x22b-instruct. (openai/gpt-4o-mini also works if you'd
# rather not use an open-weight model.)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# Google Gemini — embeddings ONLY (gemini-embedding-001, truncated to 768
# dims), free tier, no card required. Get a key at https://aistudio.google.com/apikey.
GEMINI_API_KEY=

# Telegram — create a bot via @BotFather to get the token, and pick any
# random string for the webhook secret (you'll pass it to setWebhook, see
# CLAUDE.md for the exact command).
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
